          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/consent/grant", "host": ["{{baseUrl}}"], "path": ["api", "consent", "grant"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceId\": \"your-reference-id\"\n}"
            }
          }
        },
        {
          "name": "Revoke",
          "request": {
            "method": "POST",
