            }
          }
        },
        {
          "name": "Extension",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/consent/extension", "host": ["{{baseUrl}}"], "path": ["api", "consent", "extension"] },
