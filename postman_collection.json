            }
          }
        },
        {
          "name": "Auto Expired",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/consent/auto-expired", "host": ["{{baseUrl}}"], "path": ["api", "consent", "auto-expired"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceId\": \"your-reference-id\"\n}"
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/consent/update", "host": ["{{baseUrl}}"], "path": ["api", "consent", "update"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"referenceId\": \"your-reference-id\"\n}"
            }
          }
        }
      ]
    }
  ]
}
